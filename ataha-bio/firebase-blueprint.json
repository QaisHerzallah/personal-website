{
  "entities": {
    "course": {
      "title": "Course",
      "description": "Educational course details offered by Ataha Center.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Name of the course" },
        "description": { "type": "string", "description": "Short description of the course" },
        "instructor": { "type": "string", "description": "Who will give the course" },
        "price": { "type": "string", "description": "Price of the course" },
        "startDate": { "type": "string", "description": "Start date (e.g. 2024-06-01)" },
        "startTime": { "type": "string", "description": "Start time (e.g. 18:00)" },
        "topics": { "type": "array", "description": "List of course topics" },
        "order": { "type": "number", "description": "Display order" },
        "isActive": { "type": "boolean", "description": "Whether the course is visible" }
      },
      "required": ["name", "instructor", "price"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "centerName": { "type": "string" },
        "socialMedia": { "type": "array" }
      }
    }
  },
  "firestore": {
    "courses": {
      "schema": "course",
      "description": "Educational courses"
    },
    "settings": {
      "schema": "settings",
      "description": "App-wide settings"
    }
  }
}
